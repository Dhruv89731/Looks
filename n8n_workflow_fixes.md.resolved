## NEW Node B – Code: Append afterhours
Add after **Redis GET afterhours**.

```javascript
const waId = $('Webhook1').item.json.body.waId;
const customerMsg = $('Webhook1').item.json.body.text;
const botReply = $('Message a model2').item.json.output[0].content[0].text;

// Get today's date in IST
const istDate = new Date(
  new Date().toLocaleString('en-US', { timeZone: 'Asia/Kolkata' })
);
const date = [
  istDate.getFullYear(),
  String(istDate.getMonth() + 1).padStart(2, '0'),
  String(istDate.getDate()).padStart(2, '0'),
].join('-');

// Parse existing history or start fresh
let history = [];
try {
  const existing = $json.value;
  if (existing) history = JSON.parse(existing);
  if (!Array.isArray(history)) history = [];
} catch {
  history = [];
}

// Append this conversation turn
history.push({
  time: new Date().toISOString(),
  customer: customerMsg,
  bot: botReply,
});

return [{
  json: {
    redisKey: `afterhours:${waId}:${date}`,
    redisValue: JSON.stringify(history),
  }
}];
```

